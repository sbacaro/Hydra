<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The audio engine (HydraDaemon) now runs IN-PROCESS inside this app, so the
	     app carries the entitlements the old hydrad daemon used to. NOT sandboxed:
	     it does raw Core Audio HAL, BSD multicast sockets and process taps that App
	     Sandbox would block. -->

	<!-- The app loads its own embedded frameworks, the proprietary NDI runtime and
	     the private Dante module (.dylib), plus third-party VST3 plugins — all
	     signed differently (or not at all) from the app. Library validation would
	     refuse to load them. (It also lets ad-hoc / locally signed builds load their
	     own embedded frameworks despite differing Team IDs.) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Core Audio process taps capture other apps' audio (TCC-gated by
	     NSAudioCaptureUsageDescription in Info.plist). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
