<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- UI-only client of hydrad over ws://127.0.0.1:59731.
	     Not sandboxed (matches hydrad). -->

	<!-- The app embeds HydraCore.framework (and friends). With ad-hoc / locally
	     signed builds the app and its frameworks can carry different Team IDs, and
	     Hardened Runtime's library validation then refuses to load them
	     ("different Team IDs"). Disabling library validation lets the app load its
	     own embedded frameworks regardless of signing — same as hydrad, which sets
	     this to load third-party VST3 plugins and the NDI/Dante dylibs. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
