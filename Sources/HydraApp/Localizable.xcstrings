  "strings" : {
    "" : {

    },
    "%@ \"%@\" — %lld channels" : {
      "comment" : "A context menu item that opens the StereoLink app. The argument is the string “App capture”, the string “NDI source”, the string “AES67 stream”, the string “Audio interface” or the string “Virtual interface”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ \"%2$@\" — %3$lld channels"
          }
        }
      }
    },
    "%@ \"%@\" — %lld channels. Click to %@." : {
      "comment" : "A context menu item that shows the name of a group, the number of channels in the group, and a hint to expand or collapse the group. The argument is the string “App capture”, the string “NDI source”, the string “AES67 stream”, the string “Audio interface” or the string “Virtual interface”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ \"%2$@\" — %3$lld channels. Click to %4$@."
          }
        }
      }
    },
    "%@ %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ TX on" : {
      "comment" : "A tooltip for a sidebar tag. The argument is the string “AES” or the string “NDI”.",
      "isCommentAutoGenerated" : true
    },
    "%@: %@" : {
      "comment" : "A label that combines a label and a status indicator. The argument is the label, and the second argument is the status (\"OK\" or \"needs attention\").",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@"
          }
        }
      }
    },
    "%@:%u · %@" : {
      "comment" : "A label displaying the current status of the Hydra daemon. The first argument is the hostname of the Hydra daemon. The second argument is the port of the Hydra daemon. The third argument is the version of the Hydra daemon.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@:%2$u · %3$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A picker that lets the user select the number of channels for a given interface. The argument is the label for the picker.",
      "isCommentAutoGenerated" : true
    },
    "%lld %@" : {
      "comment" : "A badge that shows the number of channels and a label (\"in\" or \"out\"). The argument is the string “in” or the string “out”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld %2$@"
          }
        }
      }
    },
    "%lld ch" : {

    },
    "%lld ch @ %lld Hz" : {
      "comment" : "A label displaying the number of channels and sample rate of an NDI source. The first argument is the number of channels. The second argument is the sample rate in Hz.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld ch @ %2$lld Hz"
          }
        }
      }
    },
    "%lld input channel%@ — what plays INTO this" : {
      "comment" : "A tooltip that describes the number of input channels and what they're connected to.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld input channel%2$@ — what plays INTO this"
          }
        }
      }
    },
    "%lld output channel%@ — what is recorded/sent FROM this" : {
      "comment" : "A label that describes the number of output channels. The argument is the count of output channels.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld output channel%2$@ — what is recorded/sent FROM this"
          }
        }
      }
    },
    "%lld selected — drag onto a receive channel; they land in sequence" : {
      "comment" : "A label that shows the number of selected channels and instructs the user to drag them onto a receive channel.",
      "isCommentAutoGenerated" : true
    },
    "%lld/%lld TX · %lld/%lld RX" : {
      "comment" : "A label showing the number of channels in use on the Hydra network. The first argument is the number of channels in use as a transmitter. The second argument is the number of channels in use as a receiver.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld/%2$lld TX · %3$lld/%4$lld RX"
          }
        }
      }
    },
    "0 dB" : {
      "comment" : "A button that resets the gain to 0 dB.",
      "isCommentAutoGenerated" : true
    },
    "32-bit float preserves headroom exactly; 24-bit PCM is smaller and what studios usually exchange." : {
      "comment" : "A description of the pros and cons of 32-bit float and 24-bit PCM recording formats.",
      "isCommentAutoGenerated" : true
    },
    "32-bit float preserves headroom exactly; 24-bit PCM is smaller and what studios usually exchange. Recordings are written to Music → Hydra Recordings unless you choose another folder." : {
      "comment" : "A longer description of recording settings.",
      "isCommentAutoGenerated" : true
    },
    "A complete audio patch bay for your Mac: route any source to any destination, capture the sound of individual apps, and connect over the network with AES67, NDI and VST3 — all in a single virtual soundcard." : {
      "localizations" : {
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um patch bay de áudio completo para o seu Mac: roteie qualquer fonte para qualquer destino, capture o som de apps individuais e conecte-se à rede com AES67, NDI e VST3 — tudo numa única placa de som virtual."
          }
        }
      }
    },
    "A named slice of the soundcard's channel pool." : {
      "comment" : "A description of the function of a virtual interface.",
      "isCommentAutoGenerated" : true
    },
