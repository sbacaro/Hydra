    "Toggle a plug-in off to hide it from the insert picker without uninstalling it. Star a plug-in to pin it to the top of the picker.": {
      "comment": "A footer for the plug-in list.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desative um plug-in para ocultá-lo do seletor de inserts sem desinstalá-lo. Favorite um plug-in para fixá-lo no topo do seletor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactiva un plug-in para ocultarlo del selector de inserts sin desinstalarlo. Marca como favorito un plug-in para fijarlo arriba del selector."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivez un plug-in pour le masquer du sélecteur d’inserts sans le désinstaller. Mettez un plug-in en favori pour l’épingler en haut du sélecteur."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte ein Plug-in aus, um es aus der Insert-Auswahl auszublenden, ohne es zu deinstallieren. Markiere ein Plug-in als Favorit, um es oben in der Auswahl anzuheften."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattiva un plug-in per nasconderlo dal selettore degli insert senza disinstallarlo. Metti tra i preferiti un plug-in per fissarlo in cima al selettore."
          }
        }
      }
