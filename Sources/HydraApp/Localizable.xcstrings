    "This plug-in hung or crashed during scanning. Fix or remove it, then Rescan.": {
      "comment": "A tooltip for an offline plug-in.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este plug-in travou ou falhou durante o escaneamento. Conserte-o ou remova-o e escaneie novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este plug-in se colgó o falló durante el escaneo. Arréglalo o quítalo, y vuelve a escanear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce plug-in s’est bloqué ou a planté pendant l’analyse. Corrigez-le ou retirez-le, puis relancez l’analyse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Plug-in hing oder stürzte beim Scannen ab. Behebe oder entferne es und scanne erneut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo plug-in si è bloccato o è andato in crash durante la scansione. Correggilo o rimuovilo, poi riscansiona."
          }
        }
      }
    },
