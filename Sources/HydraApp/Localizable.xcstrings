    "The Hydra Engine backplane is a customized BlackHole driver. GPL-3.0, same as Hydra.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O backplane Hydra Engine é um driver BlackHole personalizado. GPL-3.0, igual ao Hydra."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El backplane Hydra Engine es un driver BlackHole personalizado. GPL-3.0, igual que Hydra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le backplane Hydra Engine est un pilote BlackHole personnalisé. GPL-3.0, comme Hydra."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
